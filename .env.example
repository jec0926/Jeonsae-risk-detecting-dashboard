# Copy this file to `.env` and fill only in your local environment.
# Never commit real API keys to GitHub.

# HUG: 분양보증사고현황 API
HUG_GUARANTEE_ACCIDENT_API_KEY=your_hug_service_key_here
# HUG key parameter name may differ by issued API guide.
HUG_GUARANTEE_ACCIDENT_KEY_PARAM=serviceKey

# IROS: 근저당권 설정 등기 현황 API
IROS_MORTGAGE_API_KEY=your_iros_mortgage_key_here

# IROS: 임차권등기 설정 등기 현황 API
IROS_LEASE_RIGHT_API_KEY=your_iros_lease_right_key_here
